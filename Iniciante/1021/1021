#include <stdio.h>
#include <stdlib.h>
#include <math.h>

int main(){
    int cem, cinquenta, vinte, dez, cinco, dois, um, ccinquenta, cvintecinco, cdez, ccinco, cum; 
	double valor;
	cem = cinquenta = vinte = dez = cinco = dois = um = ccinquenta = cvintecinco = cdez = ccinco = cum = 0;

	scanf("%lf", &valor);
	
    cem = valor/100;
    valor -= cem*100;

    cinquenta = valor/50;
    valor -= cinquenta*50;

    vinte = valor/20;
    valor -= vinte*20;

    dez = valor/10;
    valor -= dez*10;

    cinco = valor/5;
    valor -= cinco*5;

    dois = valor/2;
    valor -= dois*2;

    um = valor/1;
    valor -= um*1;

    ccinquenta = valor/0.5;
    valor -= ccinquenta*0.5;

    cvintecinco = valor/0.25;
    valor -= cvintecinco*0.25;

    cdez = valor/0.10;
    valor -= cdez*0.10;

    ccinco = valor/0.05;
    valor -= ccinco*0.05;

    cum = valor/0.01; 
    valor -= cum*0.01;
	
	printf("NOTAS:\n");
	printf("%d nota(s) de R$ 100.00\n", cem);
	printf("%d nota(s) de R$ 50.00\n", cinquenta);
	printf("%d nota(s) de R$ 20.00\n", vinte);
	printf("%d nota(s) de R$ 10.00\n", dez);
	printf("%d nota(s) de R$ 5.00\n", cinco);
	printf("%d nota(s) de R$ 2.00\n", dois);
	printf("MOEDAS:\n");	
	printf("%d moeda(s) de R$ 1.00\n", um);
	printf("%d moeda(s) de R$ 0.50\n", ccinquenta);
	printf("%d moeda(s) de R$ 0.25\n", cvintecinco);
	printf("%d moeda(s) de R$ 0.10\n", cdez);
	printf("%d moeda(s) de R$ 0.05\n", ccinco);
	printf("%d moeda(s) de R$ 0.01\n", cum);

	return 0;
}